APP_ENV=development

# PostgreSQL
DATABASE_URL=postgresql+psycopg2://opera:opera@db:5432/opera_bridge

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Avatar uploads
UPLOAD_DIR=uploads

# MQTT (Legrand GRMS Guest Control Platform protocol) - test trước khi nối RCU/OPERA Cloud thật.
# Để MQTT_ENABLED=false thì backend chỉ log ra console thay vì publish thật (chạy demo không cần broker).
MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_HOTEL_ID=DEMO001
MQTT_CLIENT_ID=opera-bridge-api
